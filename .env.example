OPENAI_API_KEY=
LLM_MODEL=gpt-4o
MOCK_MODE=true
CONFIDENCE_THRESHOLD=0.85

# Circuit breaker — autonomously stop a flow (no human) after repeated contain-the-damage failures
AUTO_STOP_ENABLED=true
AUTO_STOP_FAILURE_THRESHOLD=3
AUTO_STOP_LOOKBACK_HOURS=24

# Background poller — auto-refresh live_incidents.json from the tenant on a timer
POLL_ENABLED=true
POLL_INTERVAL_SECONDS=90
